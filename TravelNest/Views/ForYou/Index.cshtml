@model IEnumerable<TravelNest.Models.Postare>
<html>
    <head>
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
        <link rel="stylesheet" href="~/css/Profil.css">
        <link rel="stylesheet" href="~/css/foryou.css">
        <link rel="stylesheet" href="~/css/comentarii.css">
        <link rel="stylesheet" href="~/css/replyComs.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    </head>
    <body>
        <i id="menuBtn" class="fa-solid fa-bars"></i>
        <div class="sideMenu">
            <img id="logoMenu" src="~/images/logoMenu.png" />
            <div id="butonMeniu">
                <a asp-controller="Profil" asp-action="Index" asp-route-id="">
                    <p>Profile</p>
                </a>
            </div>
            <div id="butonMeniu">
                <a asp-controller="Notifications" asp-action="Index">
                    <p>Notifications</p>
                    <span id="punctRosu" style="display:none;">0</span>
                </a>
            </div>
            <div id="butonMeniu">
                <a asp-controller="Chat" asp-action="Index">
                    <p>Chat</p>
                    <span id="punctRosu" style="display:none;">0</span>
                </a>
            </div>
            <div id="butonMeniu">
                <a asp-controller="ForYou" asp-action="Index">
                    <p id="paginaCurenta">For You</p>
                </a>
            </div>
            <div id="butonMeniu" class="AddPost2">
                <p>New Post</p>
            </div>
            <div id="butonMeniu">
                <a asp-controller="TravelGroup" asp-action="Index">
                    <p>New Travel Group</p>
                </a>
            </div>
            <div id="butonMeniu">
                <a asp-controller="TravelAssistant" asp-action="Index">
                    <p>Travel Assistant</p>
                </a>
            </div>
            <div id="butonMeniu">
                <p>Travel Map</p>
            </div>
            <div class="butoaneJos">

                <div id="butonMeniu">
                    <a asp-controller="Settings" asp-action="Index">
                        <p>Settings</p>
                    </a>
                </div>
                <div id="butonMeniu" class="logoutBtn">
                    <a asp-area="Identity" asp-page="/Account/Logout">
                        <p>Logout</p>
                    </a>
                </div>
            </div>
        </div>
        <div id="sectiuneForYou">
            <div id="antet">
                <div id="searchUtilizatori">
                    <i id="lupaIcon" class="fa-solid fa-magnifying-glass"></i>
                    <input id="inputCautare" type="text" placeholder="Search users..">
                    <div id="rezultateCautare" style="display: none;"></div>
                </div>
                <div id="zonaProfil">
                    <div id="butonChat">
                        <i class="fa-solid fa-comment-dots"></i>   
                    </div>
                </div>
            </div>

            <div id="postariTrending">
            @{
                var listaSugestii = ViewBag.ConturiSugerate as IEnumerable<TravelNest.Models.Profil>;
                bool existaSugestii = listaSugestii != null && listaSugestii.Any();
            }
            <div id="fluxPrincipal" class="@(existaSugestii ? "" : "faraSugestii")">
                @foreach (var post in Model)
                {
                    <div id="articol-@post.Id" class="postareFYP">

                        <div id="zonaMedia-@post.Id" class="ramaPatrata">

                            <div id="profil-@post.Id" class="antetPlutitor">
                                <a href="/Profil/Index/@post.Profil.Id" id="user-@post.Id" class="imgProfilPostare">
                                    <img src="@(string.IsNullOrEmpty(post.Profil.ImagineProfil) ? "/images/profilDefault.png" : post.Profil.ImagineProfil)" id="pozaUser-@post.Id" />
                                    <span>@post.Profil.User.UserName</span>
                                </a>
                            </div>

                            <div id="carusel-@post.Id" class="carousel slide h-100" data-bs-interval="false">
                                <div class="carousel-inner h-100">
                                    @for (int i = 0; i < post.FisiereMedia.Count; i++)
                                    {
                                        var media = post.FisiereMedia.ToList()[i];
                                        <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                            @if (media.fisier == TravelNest.Models.Tip.Image)
                                            {
                                                <img src="@media.Url" id="img-@media.Id" class="imagineFit" />
                                            }
                                            else
                                            {
                                                <video controls class="imagineFit">
                                                    <source src="@media.Url" type="video/mp4">
                                                </video>
                                            }
                                        </div>
                                    }
                                </div>

                                @if (post.FisiereMedia.Count > 1)
                                {
                                    <button id="inapoi-@post.Id" class="sageataCarusel stanga" type="button" data-bs-target="#carusel-@post.Id" data-bs-slide="prev">
                                        <i class="fas fa-chevron-left"></i>
                                    </button>
                                    <button id="inainte-@post.Id" class="sageataCarusel dreapta" type="button" data-bs-target="#carusel-@post.Id" data-bs-slide="next">
                                        <i class="fas fa-chevron-right"></i>
                                    </button>
                                }
                            </div>

                            <div id="actiuni-@post.Id" class="coloanaButoane">
                                @{
                                    bool likePostare = post.Likes.Any(l => l.UserId == ViewBag.UserLog);
                                }
                                <button id="like-@post.Id"
                                        class="butonActiune btn-like @(likePostare ? "activat" : "")"
                                        data-id="@post.Id">
                                    <i class="@(likePostare ? "fas fa-heart text-danger" : "far fa-heart")"></i>
                                    <span id="nrLike-@post.Id">@post.Likes.Count()</span>
                                </button>

                                <button id="comm-@post.Id" class="butonActiune" onclick="deschidePostare(@post.Id)">
                                    <i class="far fa-comment"></i>
                                    <span id="nrComm-@post.Id">
                                        @{
                                            int nr = post.Comentarii.Count +
                                            post.Comentarii.Sum(c => c.Raspunsuri?.Count ?? 0);
                                        }
                                        @nr
                                    </span>
                                </button>
                            </div>
                        </div>

                        <div id="detalii-@post.Id" class="sectiuneText">
                            @if (!string.IsNullOrEmpty(post.Locatie))
                            {
                                <div id="locatie-@post.Id" class="textLocatie">
                                    <i class="fas fa-location-dot"></i> @post.Locatie
                                </div>
                            }

                            <div id="continut-@post.Id" class="textDescriere">
                                <span class="numeBold">@@@post.Profil.User.UserName</span> @post.Descriere
                            </div>

                            @if (!string.IsNullOrEmpty(post.MetaDate))
                            {
                                <div id="taguriAi-@post.Id" class="zonaEtichete">
                                    @foreach (var tag in post.MetaDate.Split(", "))
                                    {
                                        <span id="tag-@post.Id-@tag" class="eticheta">#@tag</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            @if (existaSugestii)
            {
                <aside id="baraSugestii">
                    <div id="containerSugestii">
                        <h3 id="titluSugestii">Suggested accounts</h3>

                        <div id="listaConturi">
                            @if (ViewBag.ConturiSugerate != null)
                            {
                                foreach (var profil in (IEnumerable<TravelNest.Models.Profil>)ViewBag.ConturiSugerate)
                                {
                                    <div id="randSugestie-@profil.Id" class="randSugestie">
                                        <div id="infoUserSugestie">
                                            <img src="@(string.IsNullOrEmpty(profil.ImagineProfil) ? "/images/profilDefault.png" : profil.ImagineProfil)"
                                                 id="pozaSugestie-@profil.Id" class="pozaSugestie" />
                                            <div id="detaliiUserSugestie">
                                                <span id="numeSugestie-@profil.Id" class="numeSugestie">@profil.User.UserName</span>
                                            </div>
                                        </div>
                                        <a href="/Profil/Index/@profil.Id" id="linkVizualizare-@profil.Id" class="butonVizualizare">
                                            View
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </aside>
            }
        </div>
        <div id="fereastra-postare" class="modal-overlay" style="display: none;">
            <div class="modal-container">

                <span class="buton-inchidere" onclick="inchideFereastra()">&times;</span>

                <div class="zona-media">
                    <div class="media-wrapper" style="position: relative;">
                        <div id="continut-media"></div>

                        <div id="userTagsIcon" class="userTagsIcon" onclick="viewTags()" style="display: none;">
                            <i class="fa-solid fa-user-tag"></i>
                        </div>

                        <div id="listaTags" class="tags-popover" style="display: none;">
                        </div>
                    </div>

                    <div class="media-controls">
                        <button id="btn-inapoi" class="nav-btn" onclick="schimbaSlide(-1)">&#10094;</button>
                        <button id="btn-inainte" class="nav-btn" onclick="schimbaSlide(1)">&#10095;</button>
                    </div>
                </div>

                <div class="zona-detalii">
                    <div class="detalii-header">
                        <img id="header-poza-profil" src="" class="poza-rotunda">
                        <div class="text-header">
                            <span id="header-username" class="nume-bold"></span>
                            <span id="header-locatie" class="locatie-text"></span>
                        </div>
                        <div id="boxOptiuniPostari" style="margin-left: auto; position: relative; display: none;">
                            <i class="fas fa-ellipsis-h optiuni-postare-icon" onclick="afisMeniuOptiuniPostari()" style="cursor: pointer; padding: 5px;"></i>

                            <div id="MeniuOptiuniPostare" style="right: 0; top: 25px; width: 120px;">
                                <div id="OptiuniEditeazaPost" class="ElementeDinMeniu" onclick="EditarePostare()">
                                    <i class="fas fa-pencil-alt"></i> Edit
                                </div>
                                <div id="OptiuniArhiveazaPost" class="ElementeDinMeniu" onclick="ArhiveazaPostare()">
                                    <i class="fas fa-archive"></i> Archive
                                </div>
                                <div id="OptiuniStergePost" class="ElementeDinMeniu" onclick="StergerePostare()" style="color: #ed4956; border-top: 1px solid #efefef;">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="detalii-body">
                        <div class="rand-descriere">
                            <img id="body-poza-profil" src="" class="poza-rotunda mica">
                            <div class="continut-text">
                                <span id="body-username" class="nume-bold"></span>
                                <span id="descriere-text" class="text-normal"></span>
                            </div>
                        </div>
                        <div id="data-postarii" class="data-text"></div>
                        <div id="lista-comentarii"></div>
                    </div>

                    <div class="detalii-footer">

                        <div class="iconite-actiune" style="display: flex; align-items: center; gap: 20px; font-size: 1.5rem; margin-bottom: 10px;">

                            <div id="btn-like-modal" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <i class="fa-regular fa-heart" id="iconInima" style="line-height: 1;"></i>
                                <span id="text-like-count-modal" style="font-size: 1rem; font-weight: bold; line-height: 1;">0</span>
                            </div>
                            <div style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <i class="far fa-comment" id="iconComentariu"></i>
                                <span id="text-comm-count-modal" style="font-size: 1rem; font-weight: bold; line-height: 1;">0</span>
                            </div>

                        </div>
                        <div class="zona-input-comentariu">
                            <input id="input-comentariu-text" type="text" placeholder="Add a comment..." maxlength="255">
                            <button onclick="postCom()">Post</button>
                        </div>
                    </div>
                </div>
            </div>
            <div id="popupStergeCom" class="popUp" style="display: none;">
                <div class="popUpbox">
                    <h3 id="popUpTitlu">Delete this comment?</h3>
                    <p id="popUpMesaj">Are you sure you want to delete this comment? The action cannot be undone.</p>

                    <div class="butoanePopUp">
                        <button onclick="inchidePopUp()" id="btnAnularePopUp">Cancel</button>
                        <button onclick="StergeCom()" id="btnStergeComPopUp">Delete</button>
                    </div>
                </div>
            </div>
            <div id="popupStergeReply" class="popUp" style="display: none;">
                <div class="popUpbox">
                    <h3 id="popUpTitlu">Delete Reply?</h3>
                    <p id="popUpMesaj"> Are you sure you want to delete this reply?</p>
                    <div class="butoanePopUp">
                        <button id="btnAnularePopUp" onclick="inchidePopUpReply()">Cancel</button>
                        <button id="btnStergeComPopUp" onclick="ConfirmaStergereReply()">Delete</button>
                    </div>
                </div>
            </div>
            <div id="popupStergePostare" class="popUp" style="display: none;">
                <div class="popUpbox">
                    <h3 id="popUpTitlu">Delete Post?</h3>
                    <p id="popUpMesaj">Are you sure you want to delete this post? This action cannot be undone.</p>
                    <div class="butoanePopUp">
                        <button id="btnAnularePopUp" onclick="inchidePopUpPostare()">Cancel</button>
                        <button id="btnStergeComPopUp" onclick="ConfirmaStergerePostare()">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </body>
    <script src="~/js/butonSideMenu.js" asp-append-version="true"></script>
    <script src="~/js/popUpPostare.js" asp-append-version="true"></script>
    <script src="~/js/profil.js" asp-append-version="true"></script>
    <script src="~/js/replysComs.js" asp-append-version="true"></script>
    <script src="~/js/foryou.js" asp-append-version="true"></script>
</html>